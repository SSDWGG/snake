# 复制为 .env.deploy.local 后填写真实信息；不要提交 .env.deploy.local

# 腾讯云 CVM / 轻量应用服务器公网 IP 或绑定域名
DEPLOY_SSH_HOST=124.223.119.218

# 以你平时 SSH 登录服务器使用的用户名为准，常见为 root / ubuntu
DEPLOY_SSH_USER=root

# SSH 端口，未改过通常是 22
DEPLOY_SSH_PORT=22

# 推荐填写本机私钥文件路径，而不是把私钥内容写进配置文件
DEPLOY_SSH_KEY=~/.ssh/id_ed25519

# 远程部署目录
DEPLOY_REMOTE_DIR=/www/wwwroot/ryw_yun_project/snake/
