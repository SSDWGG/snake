# 复制为 .env.oss.local 后填写真实信息；不要提交 .env.oss.local
#
# 这里使用小程序/浏览器直传 OSS 的 POST policy 配置，不需要 accessKeySecret。

# 上传接口域名，对应函数里的 cdnHost。
OSS_POST_CDN_HOST=https://panshi-on.meipingmi.com.cn

# 上传路径前缀，对应函数里的 ossFilePrePath。
# MCP 默认会追加日期目录：yunxiaoding-mini/other/wggw/YYYY-MM-DD/<uuid>.<ext>
OSS_POST_PREFIX=yunxiaoding-mini/other/wggw

# POST policy 凭据，对应函数 formData 里的字段。
OSS_POST_ACCESS_KEY_ID=your-oss-access-key-id
OSS_POST_POLICY=your-policy
OSS_POST_SIGNATURE=your-signature
OSS_POST_SUCCESS_ACTION_STATUS=200
